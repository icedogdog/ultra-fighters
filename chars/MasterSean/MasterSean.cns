; Sean Hyper Portrait Helper
[Statedef 4052]
physics = N
anim = 4052
sprpriority = 5

[State 4052, Sean Hyper Portrait]
type = Explod
trigger1 = !Time
anim = 4051
ID = 4051

[State 4052, ModifyExplod]
type = ModifyExplod
trigger1 = Time < 49
ID = 4051
scale = .5,.5

[State 4052, ModifyExplod]
type = ModifyExplod
trigger1 = Time >= 49
ID = 4051
scale = .5225+(.13*(time-53)),.5225+(.13*(time-49))

[State 4052, Sean Portrait]
type = ModifyExplod
trigger1 = NumExplod(4051) && Time < 49
ID = 4051
postype = back
pos = 0,119
under = 1
bindtime = 1
removetime = 49
pausemovetime = 9999
supermovetime = 9999
accel = .14

[State 4052, Black Screen]
type = EnvColor
trigger1 = AnimElem = 1
value = 0,0,0
time = 49
under = 1
ignorehitpause = 1
persistent = 0

[State 4052, DestroySelf]
type = DestroySelf
trigger1 = Time >= 49
;---------------------------------------------------------------------------

[Statedef -2]

[State -2, Normal Attacks Damage Reduction]
type = AttackMulSet
trigger1 = Var(32) = 1
value = .2

[State -2, Damage Reduction Reset]
type = VarSet
trigger1 = MoveType = I
trigger2 = Var(30) > 0
v = 32
value = 0

[State -2, Reset to Normal Damage]
type = AttackMulSet
trigger1 = Var(32) = 0
value = 1

[State -2, KO Sound Variable]
type = VarSet
trigger1 = Alive&&var(10) > 0
trigger2= !Alive&&var(10) < 2
var(10) = IfElse(Alive,0,var(10)+1)
ignorehitpause = 1

[State -2, KO Sound]
type = PlaySnd
trigger1 = !Alive&&Var(10) = 1
trigger1 = Var(10):=2
value = 11,IfElse(StateNo = 5950,2,1)
ignorehitpause = 1

[State -2, SndPan]
type = SndPan
trigger1 = 1
channel = 0
pan = 0
ignorehitpause = 1

